ADDRESS
PUSH20 0xffffffffffffffffffffffffffffffffffffffff
AND

; The ADDRESS builtin writes a full i256, then we narrow to i160 via trunc+zext.
; LLVM converts trunc+zext to an AND, then folds the redundant opcode AND away.
; Only one AND should remain (from the narrowing), not two.
; CHECK: call void @__revmc_builtin_address(
; CHECK: [[RAW:%.*]] = load i256
; CHECK: [[ADDR:%.*]] = and i256 [[RAW]]
; CHECK-NOT: and
; CHECK: store i256 [[ADDR]]
; CHECK: ret i8
