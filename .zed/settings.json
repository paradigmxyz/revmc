{
  "lsp": {
    "rust-analyzer": {
      "initialization_options": {
        "rustfmt": {
          "extraArgs": ["+nightly"],
        },
        "cargo": {
          "allTargets": true,
          "features": ["llvm"],
          "sysroot": "discover",
        },
        "diagnostics": {
          "disabled": ["unsafe_op_in_unsafe_fn"],
        },
      },
    },
  },
}
